# macOS
.DS_Store

# Python
__pycache__/
*.pyc
venv/
.venv/

# Local secrets (GROQ_API_KEY) and Claude Code dev-server launch config —
# never commit these
.streamlit/secrets.toml
.claude/

# Raw source PDFs (manually collected, not scraped — kept local only,
# per the data-sourcing note in readme.md)
Data/raw_pdfs/

# Extracted full-text of each circular (intermediate pipeline output,
# regenerated from Data/raw_pdfs/ via extract.py)
Data/extracted/

# Local chat history — ephemeral per README, resets on Streamlit Cloud
# redeploy; may contain real user questions once deployed, so it should
# never be committed
Data/chat_history.json

# Generated locally by build_regression_set.py / manual Sheet exports —
# not something to version
Data/feedback_export.csv
regression_candidates.csv

# Eval/dedup outputs and scratch artifacts (regenerated by the eval scripts)
eval_ab_results.csv
rag_eval_upi_circulars.csv
Data/duplicate_report.csv
Data/_duplicates_removed/
Data/id_collision_report.csv
Data/verification_report.csv

# Pre-computed OCR text cache (intermediate; regenerated by scripts/ocr_pdf.py).
# Like Data/extracted/, it's a pipeline intermediate, not a source artifact.
Data/ocr_text/

# NOTE: Data/manual_patches/ IS tracked — small hand-corrected text (e.g. the
# reconstructed OC 120 Annexure A) that can't be regenerated automatically.

# Apple Numbers working files (the .csv is the source of truth)
*.numbers

# Local secrets / launch config
.streamlit/
.claude/launch.json

# Note: Data/chroma_db/ and Data/manifest.csv ARE committed intentionally —
# the prebuilt vector index is what the deployed app actually needs to run.
